# =============================================================================
# 🍕 PI-ZZA .gitignore — 機密情報とビルド生成物の徹底除外
# =============================================================================
# 方針:
#  - 秘密情報 (.env, *.key, credentials) は絶対に commit しない
#  - 言語固有のビルド成果物・キャッシュは除外
#  - gen/ (buf 生成物) と third_party/ (subtree) は *commit する* ため除外しない
#  - .env.example / *.example は commit する（テンプレートのため）

# -----------------------------------------------------------------------------
# Secrets — 最優先で除外
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
!*.public.key
*.p12
*.pfx
credentials
credentials.json
secrets
secrets.json
*.token
*.tokens
service-account*.json
gcp-credentials*.json
google-credentials*.json
firebase-credentials*.json
aws-credentials
.aws/

# -----------------------------------------------------------------------------
# OS 固有
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# エディタ / IDE
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.iml
*.swp
*.swo
*.swn
*~
.cursor/
.aider*
.zed/
.fleet/
*.sublime-*

# -----------------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------------
bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.txt
coverage.html
cover.out
*.prof
*.pprof
c.out
/pizza
/dough-service
/delivery-service
vendor/
go.work
go.work.sum

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
*.egg-info/
.eggs/
*.egg
.python-version
.venv/
venv/
env/
ENV/
# uv
.venv

# -----------------------------------------------------------------------------
# Node / TypeScript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/*
!.yarn/releases
!.yarn/patches
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.pnp.*
.next/
.turbo/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Docker / Podman / コンテナ
# -----------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.override.yaml
compose.override.yml
compose.override.yaml
.docker/
.containers/data/
*.pid

# -----------------------------------------------------------------------------
# Database / データ
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
data/
/var/
!/var/.gitkeep

# -----------------------------------------------------------------------------
# ログ / 一時ファイル
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
.tmp/
.cache/
*.bak
*.backup
*.old

# -----------------------------------------------------------------------------
# Streamlit (M4 Box UI)
# -----------------------------------------------------------------------------
.streamlit/secrets.toml

# -----------------------------------------------------------------------------
# Claude Code / Agent local state
# -----------------------------------------------------------------------------
.claude/
.plan/
CLAUDE.local.md

