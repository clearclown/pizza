# =============================================================================
# 🍕 PI-ZZA 環境変数テンプレート (.env.example)
# -----------------------------------------------------------------------------
# このファイルを `.env` にコピーして実値を埋めてください。
#     cp .env.example .env
#
# `.env` は .gitignore により絶対に commit されません。
# API キーを公開リポジトリに push しないよう注意してください。
# =============================================================================


# =============================================================================
# 🗺 Core — Google Maps API
# =============================================================================
# https://console.cloud.google.com/apis/credentials で API キーを発行し、
# 「Places API (New)」「Maps JavaScript API」「Geocoding API」を有効化してください。
# アプリケーション制限: HTTP referrer（本番時）, IP アドレス（サーバ実行時）
GOOGLE_MAPS_API_KEY=
# 1 にした時だけ Google Maps Platform の有料 API を許可
PIZZA_ENABLE_PAID_GOOGLE_APIS=0
# 任意: Places API の言語 / 地域 (ja, JP がデフォルト)
GOOGLE_MAPS_LANGUAGE=ja
GOOGLE_MAPS_REGION=JP


# =============================================================================
# 🧀 Firecrawl — M2 Kitchen Module
# -----------------------------------------------------------------------------
# セルフホスト Docker / Firecrawl Cloud (SaaS) の両対応。
# FIRECRAWL_MODE で切替: docker / saas
# =============================================================================
FIRECRAWL_MODE=docker

# --- docker モード時（セルフホスト。AGPL 条項に留意。docs/license-compliance.md 参照）
# ローカル docker compose の場合: http://firecrawl:3002
# 自マシン直接: http://localhost:3002
FIRECRAWL_API_URL=http://localhost:3002

# --- saas モード時（Firecrawl Cloud。https://www.firecrawl.dev で発行）
FIRECRAWL_API_KEY=
# SaaS エンドポイント（通常は既定で OK）
# FIRECRAWL_SAAS_URL=https://api.firecrawl.dev

# --- 共通オプション
FIRECRAWL_TIMEOUT_MS=30000
FIRECRAWL_MAX_RETRIES=3


# =============================================================================
# 🤖 LLM Multi-Provider — M3 Delivery Module
# -----------------------------------------------------------------------------
# LLM_PROVIDER で使用するプロバイダを切替。各プロバイダの API キーは
# そのプロバイダを使うときだけ必須です。
# =============================================================================
LLM_PROVIDER=anthropic

# 全プロバイダ共通のデフォルト: 空なら各プロバイダの default_model が使われる
LLM_MODEL=

# 判定用パラメータ（Phase 3 で実装）
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SEC=60


# -----------------------------------------------------------------------------
# 🟣 Anthropic Claude
# -----------------------------------------------------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# モデル選択肢（2026-04 時点）:
#   claude-opus-4-7          ← 最高精度。FC 判定のメイン（推奨）
#   claude-sonnet-4-6        ← 速度と精度のバランス
#   claude-haiku-4-5-20251001 ← 高速・低コスト。バッチ処理向け
ANTHROPIC_MODEL=claude-opus-4-7

# エンタープライズ利用時の API base URL 上書き (通常は不要)
# ANTHROPIC_BASE_URL=https://api.anthropic.com


# -----------------------------------------------------------------------------
# 🟢 OpenAI
# -----------------------------------------------------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# モデル選択肢:
#   gpt-4o             ← Vision + text の旗艦（推奨）
#   gpt-4o-mini        ← 高速・低コスト
#   o1                 ← 推論特化（複雑判定用）
#   o3-mini            ← 高速推論
OPENAI_MODEL=gpt-4o

# 組織ID（プロジェクト課金を分けたい場合）
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Azure OpenAI / カスタム endpoint を使う場合
# OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/v1
# OPENAI_API_VERSION=2024-10-01


# -----------------------------------------------------------------------------
# 🔵 Google Gemini
# -----------------------------------------------------------------------------
# https://aistudio.google.com/app/apikey （AI Studio）
# または https://console.cloud.google.com で Vertex AI 経由
GEMINI_API_KEY=

# モデル選択肢:
#   gemini-2.0-flash       ← 高速・コスパ良好（推奨デフォルト）
#   gemini-2.0-pro         ← 長文コンテキスト / 複雑判定
#   gemini-1.5-pro         ← 旧世代の安定版
GEMINI_MODEL=gemini-2.0-flash

# Vertex AI 経由時（GCP プロジェクト連携）
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=<your-gcp-project>
# GOOGLE_CLOUD_LOCATION=us-central1


# =============================================================================
# 🛰 gRPC サービスアドレス
# -----------------------------------------------------------------------------
# docker compose で起動する場合は service 名で解決されます:
#   SEED_SERVICE_ADDR=dough-service:50051
#   DELIVERY_SERVICE_ADDR=delivery-service:50053
# =============================================================================
SEED_SERVICE_ADDR=localhost:50051
DELIVERY_SERVICE_ADDR=localhost:50053

# gRPC keepalive (ms)
GRPC_KEEPALIVE_TIME_MS=10000
GRPC_KEEPALIVE_TIMEOUT_MS=3000


# =============================================================================
# 📦 ストレージ — M4 Box Module
# =============================================================================
PIZZA_DB_PATH=./var/pizza.sqlite
PIZZA_OUTPUT_DIR=./var/output


# =============================================================================
# ⚙️  実行制御
# =============================================================================
LOG_LEVEL=info                              # debug | info | warn | error
MAX_CONCURRENCY=8                           # Maps / Firecrawl / LLM の並列上限
GRID_CELL_KM=1.0                            # メッシュセル幅 (km)
MEGA_FRANCHISEE_THRESHOLD=20                # メガジー判定の店舗数閾値

# リトライ・バックオフ
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=500
RETRY_MAX_DELAY_MS=30000


# =============================================================================
# 🔭 Observability (optional — Phase 2+)
# =============================================================================
# OpenTelemetry OTLP エクスポータ
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=pizza-orchestrator
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1

# Sentry DSN (error tracking)
# SENTRY_DSN=


# =============================================================================
# 🧪 開発用 (任意)
# =============================================================================
# PYTHONDONTWRITEBYTECODE=1
# PYTHONUNBUFFERED=1
# GO_TEST_TIMEOUT=60s
