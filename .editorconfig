# 🍕 PI-ZZA — 全言語共通エディタルール
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{md,mdx,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yaml,yml,json,toml}]
indent_size = 2

[*.proto]
indent_size = 2
